<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── HEADER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_button_green"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₽"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/black" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Palk"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="8dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="App"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/accent" />

            <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/langRu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RU"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_muted"
                    android:background="@drawable/bg_lang_pill_inactive"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/langEn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EN"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_muted"
                    android:background="@drawable/bg_lang_pill_inactive"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/langEt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ET"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent"
                    android:background="@drawable/bg_lang_pill_active"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── INPUT CARD ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/bg_glow_line"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvInputLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BRUTOPALK"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/text_muted"
                android:letterSpacing="0.12"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_field"
                android:padding="14dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="€"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#9900FF87"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/salaryInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:inputType="numberDecimal"
                    android:background="@null"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp" />

                <TextView
                    android:id="@+id/tvInputUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/ kuus"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── CALCULATE BUTTON ── -->
        <TextView
            android:id="@+id/calcButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="⚡ Arvuta"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:background="@drawable/bg_button_green"
            android:layout_marginBottom="14dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- ── RESULTS CARD ── -->
        <LinearLayout
            android:id="@+id/cardResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/bg_glow_line"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvResultLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TULEMUSED"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/text_muted"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp" />

            <!-- Net + Employer row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NETOPALK"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvNet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_employer_badge"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/tvEmployerLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TÖÖANDJA KOKKU"
                        android:textSize="9sp"
                        android:textColor="@color/text_muted"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvTotalEmployer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Donut + Legend row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChart"
                    android:layout_width="110dp"
                    android:layout_height="110dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <!-- Legend: Net -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="7dp">
                        <View android:layout_width="8dp" android:layout_height="8dp"
                            android:background="@color/accent" android:layout_marginEnd="7dp" />
                        <TextView android:id="@+id/tvLegendNetLabel" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Netopalk" android:textSize="10sp" android:textColor="@color/text_muted" />
                        <TextView android:id="@+id/tvLegendNet" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textSize="11sp" android:textStyle="bold" android:textColor="@color/accent" />
                    </LinearLayout>

                    <!-- Legend: Social -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="7dp">
                        <View android:layout_width="8dp" android:layout_height="8dp"
                            android:background="@color/color_social" android:layout_marginEnd="7dp" />
                        <TextView android:id="@+id/tvLegendSocialLabel" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Sotsiaalmaks" android:textSize="10sp" android:textColor="@color/text_muted" />
                        <TextView android:id="@+id/tvLegendSocial" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textSize="11sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <!-- Legend: Tax -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="7dp">
                        <View android:layout_width="8dp" android:layout_height="8dp"
                            android:background="@color/color_tax" android:layout_marginEnd="7dp" />
                        <TextView android:id="@+id/tvLegendTaxLabel" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Tulumaks" android:textSize="10sp" android:textColor="@color/text_muted" />
                        <TextView android:id="@+id/tvLegendTax" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textSize="11sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                    </LinearLayout>

                    <!-- Legend: Contributions -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <View android:layout_width="8dp" android:layout_height="8dp"
                            android:background="@color/color_contrib" android:layout_marginEnd="7dp" />
                        <TextView android:id="@+id/tvLegendContribLabel" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Teie maksed" android:textSize="10sp" android:textColor="@color/text_muted" />
                        <TextView android:id="@+id/tvLegendContrib" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textSize="11sp" android:textStyle="bold" android:textColor="@color/text_primary" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#0FFFFFFF"
                android:layout_marginBottom="12dp" />

            <!-- ── DETAIL ROWS ── -->
            <include layout="@layout/item_detail_row"
                android:id="@+id/rowSocialTax"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <include layout="@layout/item_detail_row"
                android:id="@+id/rowUnemplEmployer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <include layout="@layout/item_detail_row"
                android:id="@+id/rowPension"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <include layout="@layout/item_detail_row"
                android:id="@+id/rowUnemplEmployee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <include layout="@layout/item_detail_row"
                android:id="@+id/rowIncomeTax"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <include layout="@layout/item_detail_row"
                android:id="@+id/rowNet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- ── FOOTER ── -->
        <TextView
            android:id="@+id/footerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© 2026 PalkApp · palkapp.info@gmail.com"
            android:textSize="10sp"
            android:textColor="@color/text_muted"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="16dp" />

    </LinearLayout>
</ScrollView>
